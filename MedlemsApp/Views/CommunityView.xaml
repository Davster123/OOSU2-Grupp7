<Window x:Class="MedlemsApp.Views.CommunityView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Community"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F6">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Community"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   Foreground="#2C3E50"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Medlemmar}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border Width="220"
                                Background="White"
                                CornerRadius="12"
                                Margin="10"
                                Padding="15">

                            <StackPanel HorizontalAlignment="Center">

                                <Grid Width="80" Height="80" Margin="0,0,0,10">

                                    <Ellipse Fill="#E9ECEF"
                                             Stroke="#3498DB"
                                             StrokeThickness="1"/>

                                    <Ellipse Width="76" Height="76">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding Profilbild}"
                                                        Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                </Grid>

                                <TextBlock Text="{Binding Namn}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Medlemsnivå"
                                           Foreground="Gray"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="{Binding MedlemskapsNivå}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#2980B9"
                                           HorizontalAlignment="Center"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Stäng"
                    Command="{Binding StängCommand}"
                    Width="120"
                    Height="40"
                    Background="#34495E"
                    Foreground="White"/>

        </StackPanel>

    </Grid>
</Window>
