<Window x:Class="MedlemsApp.Views.MedlemProfilView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MedlemsApp.Views"
        mc:Ignorable="d"
        Title="MedlemProfilView" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5" ResizeMode="NoResize">
    <Grid Margin="30">
        <StackPanel>
            <Grid HorizontalAlignment="Center" Margin="0,0,0,20">
                <Ellipse Width="120" Height="120" Fill="#E9ECEF" Stroke="#3498DB" StrokeThickness="2"/>
                <Ellipse Width="120" Height="120">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding InloggadMedlem.Profilbild}" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <Button Command="{Binding BytBildCommand}" Content="📷" 
                        Width="35" Height="35" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                        Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="18"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <TextBlock Text="Kontaktuppgifter" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="E-post" FontSize="12" Foreground="Gray"/>
            <TextBox Text="{Binding Email}" Height="35" Margin="0,5,0,15" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Telefon" FontSize="12" Foreground="Gray"/>
            <TextBox Text="{Binding Telefon}" Height="35" Margin="0,5,0,15" VerticalContentAlignment="Center" Padding="5,0"/>

            <TextBlock Text="Nytt Lösenord" FontSize="12" Foreground="Gray"/>
            <TextBox Text="{Binding NyttLosenord}" Height="35" Margin="0,5,0,25" VerticalContentAlignment="Center" Padding="5,0"/>

            <UniformGrid Columns="2" Margin="0,10,0,0">
                <Button Content="Spara" 
            Command="{Binding SparaCommand}" 
            Height="40" Margin="0,0,5,0"
            Background="#27AE60" Foreground="White" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Tillbaka" 
            Command="{Binding TillbakaCommand}" 
            Height="40" Margin="5,0,0,0"
            Background="Transparent" Foreground="#7F8C8D" BorderBrush="#95A5A6" BorderThickness="1">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
