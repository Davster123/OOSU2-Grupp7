<Window x:Class="MedlemsApp.Views.BokaResursView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MedlemsApp.Views"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="BokaResursView" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F4F7F6">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,30,0">
            <TextBlock Text="1. Välj Datum" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2C3E50"/>
            <Border Background="White" CornerRadius="15" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>
                </Border.Effect>
                <Calendar SelectedDate="{Binding Valdatum}" 
                          DisplayDateStart="{x:Static sys:DateTime.Now}" 
                          HorizontalAlignment="Center" BorderThickness="0"/>
            </Border>

            <Border Background="#E8F4FD" CornerRadius="10" Margin="0,20,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Valt datum:" Foreground="#5D6D7E" FontSize="12"/>
                    <TextBlock Text="{Binding Valdatum, StringFormat={}{0:D}}" FontSize="18" FontWeight="Bold" Foreground="#2980B9"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="2. Bokningsdetaljer" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

                    <TextBlock Text="Välj Resurs" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Resurser}" 
                              SelectedItem="{Binding ValdResurs}" 
                              DisplayMemberPath="Typ" 
                              Height="40" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                    <Border Background="#F8F9FA" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{Binding ValdResurs.Beskrivning, TargetNullValue='Välj en resurs för att se beskrivning.'}" 
                                       TextWrapping="Wrap" FontSize="13" Foreground="#5D6D7E" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Max kapacitet: " FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="{Binding ValdResurs.Kapacitet, StringFormat='{}{0} personer'}" 
                                           FontSize="13" Foreground="#2980B9" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Välj Utrustning (valfritt)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding UtrustningsAlternativ}" 
                              SelectedItem="{Binding ValdUtrustning}" 
                              DisplayMemberPath="ArtikelNamn" 
                              Height="40" Margin="0,0,0,20" VerticalContentAlignment="Center"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0">
                            <TextBlock Text="Start (tt:mm)" FontSize="12" Foreground="Gray"/>
                            <TextBox Text="{Binding StartTid}" Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0">
                            <TextBlock Text="Slut (tt:mm)" FontSize="12" Foreground="Gray"/>
                            <TextBox Text="{Binding SlutTid}" Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Anteckningar (Ansvarig, inbjudna, etc.)" FontSize="12" Foreground="Gray" Margin="0,10,0,5"/>
                            <TextBox Text="{Binding Deltagare}" 
             Height="80" 
             TextWrapping="Wrap" 
             AcceptsReturn="True" 
             VerticalContentAlignment="Top" 
             Padding="5"/>
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="0,10,0,0">
                        <Button Content="Boka" Command="{Binding BokaCommand}" 
                                Height="45" Margin="0,0,5,0" Background="#27AE60" Foreground="White" FontWeight="Bold"/>
                        <Button Content="Tillbaka" Command="{Binding AvbrytCommand}" 
                                Height="45" Margin="5,0,0,0" Background="Transparent" Foreground="#E74C3C" BorderBrush="#E74C3C"/>
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
