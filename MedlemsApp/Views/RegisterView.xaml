<Window x:Class="MedlemsApp.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MedlemsApp.ViewModels"
        mc:Ignorable="d"
        Title="Registrera Ny Medlem" Height="600" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.DataContext>
        <vm:RegisterViewModel />
    </Window.DataContext>

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Skapa Konto" FontSize="28" FontWeight="Bold" 
                       Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#333"/>

            <TextBlock Text="Namn / Företag:" Margin="0,5,0,2"/>
            <TextBox Text="{Binding Namn, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="E-post (används vid inloggning):" Margin="0,5,0,2"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Telefonnummer:" Margin="0,5,0,2"/>
            <TextBox Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged}" 
                     Height="30" VerticalContentAlignment="Center" Margin="0,0,0,25"/>
            
            <TextBlock Text="Välj lösenord:" Margin="0,5,0,2"/>
            <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
         Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>
            <Button Content="Registrera" 
                    Command="{Binding RegisterCommand}" 
                    Height="40" Background="#FF89CE7F" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Tillbaka till inloggning" 
        Command="{Binding TillbakaCommand}" 
        Margin="0,15,0,0" 
        Background="Transparent" 
        BorderThickness="0" 
        Foreground="Gray" 
        Cursor="Hand" 
        FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>