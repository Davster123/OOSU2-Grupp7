<Window x:Class="MedlemsApp.Views.BokningsHistorikView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MedlemsApp.Views"
        mc:Ignorable="d"
        Title="BokningsHistorikView" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F4F7F6">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Min Bokningshistorik" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding MinaBokningar}" 
                  SelectedItem="{Binding ValdBokning}"
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="White" RowHeight="40" SelectionMode="Single"
                  BorderThickness="0" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Datum" Binding="{Binding Datum, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTextColumn Header="Resurs" Binding="{Binding Resurs.Typ}" Width="*"/>
                <DataGridTextColumn Header="Tid" Width="150">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0:hh\:mm} - {1:hh\:mm}">
                            <Binding Path="Starttid"/>
                            <Binding Path="Sluttid"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Anteckningar" Binding="{Binding Deltagare}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Ändra tid" Command="{Binding ÄndraBokningCommand}" 
                    Width="120" Height="40" Background="#3498DB" Foreground="White" Margin="0,0,10,0"/>

            <Button Content="Avboka" Command="{Binding AvbokaCommand}" 
                    Width="120" Height="40" Background="#E74C3C" Foreground="White" Margin="0,0,10,0"/>

            <Button Content="Tillbaka" Command="{Binding TillbakaCommand}" 
                    Width="120" Height="40" Background="Transparent" Foreground="#7F8C8D" BorderBrush="#95A5A6" BorderThickness="1"/>
        </StackPanel>
    </Grid>
</Window>
