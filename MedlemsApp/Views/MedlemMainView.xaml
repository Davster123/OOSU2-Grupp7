<Window x:Class="MedlemsApp.Views.MedlemMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MedlemsApp.Views"
        mc:Ignorable="d"
        Title="MedlemMainView" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="SAMVERKET" Foreground="White" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,20,0,40"/>

                <Button Content="🏠 Översikt" Command="{Binding VisaOversiktCommand}" 
                        Margin="0,5" Height="40" Background="#34495E" Foreground="White" 
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Button Content="📅 Boka Resurs" Command="{Binding VisaBokningCommand}" 
                        Margin="0,5" Height="40" Background="#34495E" Foreground="White" 
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Button Content="📜 Historik" Margin="0,5" Height="40" Command="{Binding VisaHistorikCommand}"
                        Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Button Content="👤 Min Profil" Command="{Binding VisaProfilCommand}"
                        Margin="0,5" Height="40" Background="#34495E" Foreground="White" 
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Separator Margin="0,20" Background="#455A64"/>

                <Button Content="Logga ut" Command="{Binding LoggaUtCommand}" 
                        Background="#E74C3C" Foreground="White" Margin="10,100,10,0" Height="35"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Margin="30">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Grid Width="120" Height="120" Margin="0,0,20,0">
                    <Ellipse Fill="#E9ECEF" Stroke="#3498DB" StrokeThickness="1"/>
                    <Ellipse Width="116" Height="116">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding InloggadMedlem.Profilbild}" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="👤" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="#ADB5BD">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InloggadMedlem.Profilbild}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Text="{Binding InloggadMedlem.Namn, StringFormat='Välkommen tillbaka, {0}!'}" 
                           FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Columns="3" Height="120" Margin="0,20,0,0">
                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Dina Poäng" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.Poäng}" FontSize="32" FontWeight="Bold" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Medlemsnivå" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.MedlemskapsNivå}" FontSize="24" FontWeight="Bold" Foreground="#2980B9"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Betalstatus" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.Betalstatus}" FontSize="24" FontWeight="Bold" Foreground="#F39C12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Din Aktivitet" FontSize="20" FontWeight="Bold" Margin="5,30,0,10" Foreground="#2C3E50"/>

            <UniformGrid Columns="2" Height="100">
                <Border Background="#E8F4FD" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Bokad tid totalt" Foreground="#2980B9" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalTimmar, StringFormat='{}{0:N1} timmar'}" 
                                   FontSize="26" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>

                <Border Background="#E8F8F2" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Mest använda typ" Foreground="#27AE60" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MestAnvandaResurs}" 
                                   FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
