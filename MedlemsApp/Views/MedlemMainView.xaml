<Window x:Class="MedlemsApp.Views.MedlemMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedlemMainView" Height="800" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="SAMVERKET" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,40"/>
                <Button Content="🌐 Community" Command="{Binding VisaCommunityCommand}" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                <Button Content="📅 Boka Resurs" Command="{Binding VisaBokningCommand}" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Button Content="📜 Historik" Command="{Binding VisaHistorikCommand}" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Button Content="👤 Min Profil" Command="{Binding VisaProfilCommand}" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0"/>
                <Separator Margin="0,20"/>
                <Button Content="Logga ut" Command="{Binding LoggaUtCommand}" Background="#E74C3C" Foreground="White" Margin="10,100,10,0" Height="35"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Margin="30">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <Grid Width="120" Height="120" Margin="0,0,25,0">
                    <Ellipse Fill="#E9ECEF" Stroke="#3498DB" StrokeThickness="3"/>
                    <Ellipse Width="112" Height="112">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding InloggadMedlem.Profilbild}" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Inloggad som" FontSize="14" Foreground="Gray" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding InloggadMedlem.Namn, StringFormat='Välkommen, {0}!'}"
                               FontSize="32" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
            </StackPanel>

            <UniformGrid Columns="3" Height="140" Margin="0,10,0,0">
                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Dina Poäng" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.Poäng}" FontSize="32" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="{Binding RabattInfo}" FontSize="12" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Medlemsnivå" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.MedlemskapsNivå}" FontSize="24" FontWeight="Bold" Foreground="#2980B9"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Betalstatus" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.Betalstatus}" FontSize="24" FontWeight="Bold" Foreground="#F39C12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="Din Aktivitet" FontSize="20" FontWeight="Bold" Margin="5,30,0,10" Foreground="#2C3E50"/>

            <UniformGrid Columns="2" Height="100">
                <Border Background="#E8F4FD" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Bokad tid totalt" Foreground="#2980B9" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalTimmar, StringFormat='{}{0:N1} timmar'}" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#E8F8F2" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Mest använda typ" Foreground="#27AE60" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MestAnvandaResurs}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>