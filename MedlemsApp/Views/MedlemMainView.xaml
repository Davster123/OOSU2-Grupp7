<Window x:Class="MedlemsApp.Views.MedlemMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MedlemsApp.Views"
        mc:Ignorable="d"
        Title="MedlemMainView" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2C3E50" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock Text="SAMVERKET" Foreground="White" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,20,0,40"/>

                <Button Content="🏠 Översikt" 
        Command="{Binding VisaOversiktCommand}" 
        Margin="0,5" Height="40" 
        Background="#34495E" Foreground="White" 
        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Button Content="📅 Boka Resurs" 
        Command="{Binding VisaBokningCommand}" 
        Margin="0,5" Height="40" 
        Background="#34495E" Foreground="White" 
        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Button Content="📜 Historik" 
        Margin="0,5" Height="40" 
        Background="#34495E" Foreground="White" 
        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>

                <Button Content="👤 Min Profil" 
        Margin="0,5" Height="40" 
        Command="{Binding VisaProfilCommand}"
        Background="#34495E" Foreground="White" 
        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                <Separator Margin="0,20" Background="#455A64"/>

                <Button Content="Logga ut" Command="{Binding LoggaUtCommand}" 
                        Background="#E74C3C" Foreground="White" Margin="10,100,10,0" Height="35"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Margin="30">
            <TextBlock Text="{Binding InloggadMedlem.Namn, StringFormat='Välkommen tillbaka, {0}!'}" 
                       FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>

            <UniformGrid Columns="3" Height="120" Margin="0,20,0,0">
                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Dina Poäng" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.Poäng}" FontSize="32" FontWeight="Bold" Foreground="#27AE60"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Medlemsnivå" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.MedlemskapsNivå}" FontSize="24" FontWeight="Bold" Foreground="#2980B9"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="10" Margin="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Betalstatus" Foreground="Gray"/>
                        <TextBlock Text="{Binding InloggadMedlem.Betalstatus}" FontSize="24" FontWeight="Bold" Foreground="#F39C12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
