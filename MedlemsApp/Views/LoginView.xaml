<Window x:Class="MedlemsApp.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedlemsApp.ViewModels"
        Title="Samverket - Logga in" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Medlemsinloggning" FontSize="26" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,25" Foreground="#333"/>

            <TextBlock Text="E-post:" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     Height="35" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Lösenord:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordInput" 
             Height="35" 
             VerticalContentAlignment="Center" 
             Margin="0,0,0,25"/>

            <Button Content="Logga in" 
            Command="{Binding LoginCommand}" 
            CommandParameter="{Binding ElementName=PasswordInput}"
            Height="45" Background="#007ACC" Foreground="White" FontWeight="Bold">
            </Button>

            <Button Content="Avbryt" 
                    Command="{Binding TillbakaCommand}"
                    Margin="0,10,0,0" Background="Transparent" BorderThickness="0" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>