<Window x:Class="MedlemsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedlemsApp.ViewModels"
        Title="Samverket - Medlemsportal" Height="400" Width="600"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Välkommen till Samverket" FontSize="32" FontWeight="Bold" 
                       Margin="0,0,0,10" HorizontalAlignment="Center" Foreground="#333"/>

            <TextBlock Text="Logga in för att boka resurser eller skapa ett nytt konto" 
                       FontSize="16" Margin="0,0,0,40" HorizontalAlignment="Center" Foreground="#666"/>

            <UniformGrid Columns="2" Width="400">
                <Button Content="Logga in" 
                        Command="{Binding VisaLoginCommand}" 
                        Height="50" Margin="10" Background="#007ACC" Foreground="White" 
                        FontWeight="Bold" FontSize="18" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Registrera" 
                        Command="{Binding VisaRegisterCommand}" 
                        Height="50" Margin="10" Background="#FF89CE7F" Foreground="White" 
                        FontWeight="Bold" FontSize="18" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>

        </StackPanel>
    </Grid>
</Window>