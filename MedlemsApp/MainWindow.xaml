<Window x:Class="MedlemsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedlemsApp.ViewModels"
        Title="Samverket - Medlemsportal" Height="500" Width="600"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="40">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Samverket" FontSize="40" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,10"/>

            <TextBlock Text="Välj ett alternativ nedan för att fortsätta" 
                       FontSize="16" Foreground="#7F8C8D" Margin="0,0,0,40" HorizontalAlignment="Center"/>

            <UniformGrid Columns="2" Width="450">
                <Button Content="Logga in" 
                        Command="{Binding VisaLoginCommand}" 
                        Height="60" Margin="10" Background="#3498DB" Foreground="White" 
                        FontSize="18" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Bli Medlem" 
                        Command="{Binding VisaRegisterCommand}" 
                        Height="60" Margin="10" Background="#2ECC71" Foreground="White" 
                        FontSize="18" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>

            <Rectangle Height="1" Fill="#DCDDE1" Margin="20,40,20,20" Width="400"/>

            <Button Content="🔑 Personal Inloggning" 
                    Command="{Binding VisaPersonalLoginCommand}" 
                    Width="250" Height="40" Background="Transparent" BorderBrush="#95A5A6" 
                    Foreground="#7F8C8D" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Grid>
</Window>